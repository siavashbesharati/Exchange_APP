@model ForexExchange.Models.Order
@using ForexExchange.Extensions
@inject ForexExchange.Services.ISettingsService SettingsService

@{
    // Obfuscated receipt number:
    //   receipt = (orderId * 73) + 100000
    // Reverse:
    //   orderId = (receipt - 100000) / 73
    const long receiptMultiplier = 73;
    const long receiptOffset = 100000;
    var receiptNumber = (Model.Id * receiptMultiplier) + receiptOffset;

    ViewData["Title"] = $"جزئیات معامله {receiptNumber}";

    var logoDataUrl = await SettingsService.GetLogoDataUrlAsync();
    var websiteName = await SettingsService.GetWebsiteNameAsync();

    var fromCode = Model.FromCurrency?.Code ?? "";
    var toCode = Model.ToCurrency?.Code ?? "";
    var fromLabel = fromCode == "IRR" ? "Toman" : (Model.FromCurrency?.PersianName ?? fromCode);
    var toLabel = toCode == "IRR" ? "Toman" : (Model.ToCurrency?.PersianName ?? toCode);
    var customerTitle = Model.Customer == null
        ? ""
        : (Model.Customer.Gender ? "آقای" : "خانم");

    var statusText = Model.IsDeleted ? "حذف شده" : Model.IsFrozen ? "منجمد" : "تایید شد";
    var statusClass = Model.IsDeleted ? "is-deleted" : Model.IsFrozen ? "is-frozen" : "is-ok";
}

<style>
    .od-page {
        --od-bg: #f4f6f8;
        --od-card: #ffffff;
        --od-text: #0f172a;
        --od-muted: #64748b;
        --od-border: #e2e8f0;
        --od-green: #059669;
        --od-red: #dc2626;
        --od-blue: #2563eb;
        max-width: 720px;
        margin: 0 auto;
        padding: 0.75rem 0.85rem 5.5rem;
        min-height: 100dvh;
        box-sizing: border-box;
    }

    .od-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin-bottom: 0.85rem;
    }

    .od-brand {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        min-width: 0;
    }

    .od-brand img {
        width: 40px;
        height: 40px;
        object-fit: contain;
        border-radius: 10px;
        background: #fff;
        border: 1px solid var(--od-border);
        flex-shrink: 0;
    }

    .od-brand-text {
        min-width: 0;
    }

    .od-brand-text .name {
        font-weight: 800;
        font-size: 0.95rem;
        color: var(--od-text);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .od-brand-text .sub {
        font-size: 0.75rem;
        color: var(--od-muted);
    }

    .od-status {
        flex-shrink: 0;
        border-radius: 999px;
        padding: 0.35rem 0.75rem;
        font-size: 0.78rem;
        font-weight: 800;
        border: 1px solid transparent;
    }

    .od-status.is-ok {
        color: var(--od-green);
        background: #ecfdf5;
        border-color: #a7f3d0;
    }

    .od-status.is-frozen {
        color: var(--od-blue);
        background: #eff6ff;
        border-color: #bfdbfe;
    }

    .od-status.is-deleted {
        color: var(--od-red);
        background: #fef2f2;
        border-color: #fecaca;
    }

    .od-card {
        background: var(--od-card);
        border: 1px solid var(--od-border);
        border-radius: 16px;
        padding: 1rem;
        margin-bottom: 0.75rem;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }

    .od-card-title {
        font-size: 0.78rem;
        font-weight: 700;
        color: var(--od-muted);
        margin-bottom: 0.65rem;
        letter-spacing: 0.02em;
    }

    .od-receipt {
        text-align: center;
        padding: 1rem 0.75rem;
    }

    .od-receipt .label {
        font-size: 0.78rem;
        color: var(--od-muted);
        margin-bottom: 0.25rem;
    }

    .od-receipt .number {
        font-size: clamp(1.4rem, 5vw, 1.85rem);
        font-weight: 800;
        color: var(--od-text);
        direction: ltr;
        unicode-bidi: plaintext;
        letter-spacing: 0.03em;
    }

    .od-customer {
        text-align: center;
    }

    .od-customer .name {
        font-size: 1.05rem;
        font-weight: 800;
        color: var(--od-text);
        margin-bottom: 0.25rem;
    }

    .od-customer .phone {
        font-size: 0.92rem;
        color: var(--od-muted);
        direction: ltr;
        unicode-bidi: plaintext;
    }

    .od-exchange {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        gap: 0.55rem;
        align-items: center;
    }

    .od-amount {
        border-radius: 14px;
        padding: 0.85rem 0.55rem;
        text-align: center;
        border: 1px solid var(--od-border);
        min-width: 0;
    }

    .od-amount.receive {
        background: #f0fdf4;
        border-color: #bbf7d0;
    }

    .od-amount.pay {
        background: #fef2f2;
        border-color: #fecaca;
    }

    .od-amount .tag {
        display: block;
        font-size: 0.72rem;
        font-weight: 700;
        color: var(--od-muted);
        margin-bottom: 0.35rem;
    }

    .od-amount .value {
        display: block;
        font-size: clamp(0.95rem, 3.8vw, 1.15rem);
        font-weight: 800;
        color: var(--od-text);
        direction: ltr;
        unicode-bidi: plaintext;
        word-break: break-word;
    }

    .od-amount .currency {
        display: block;
        margin-top: 0.2rem;
        font-size: 0.75rem;
        color: var(--od-muted);
        font-weight: 600;
    }

    .od-arrow {
        color: var(--od-muted);
        font-size: 1rem;
    }

    .od-meta {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.65rem;
    }

    .od-meta-item {
        background: #f8fafc;
        border: 1px solid var(--od-border);
        border-radius: 12px;
        padding: 0.7rem 0.75rem;
        min-width: 0;
    }

    .od-meta-item .k {
        display: block;
        font-size: 0.72rem;
        color: var(--od-muted);
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .od-meta-item .v {
        display: block;
        font-size: 0.88rem;
        font-weight: 700;
        color: var(--od-text);
        word-break: break-word;
    }

    .od-meta-item .v.ltr {
        direction: ltr;
        unicode-bidi: plaintext;
    }

    .od-notes {
        font-size: 0.9rem;
        color: var(--od-text);
        white-space: pre-wrap;
        line-height: 1.5;
    }

    .od-actions {
        position: fixed;
        inset-inline: 0;
        bottom: 0;
        z-index: 40;
        background: rgba(255, 255, 255, 0.92);
        backdrop-filter: blur(10px);
        border-top: 1px solid var(--od-border);
        padding: 0.65rem 0.85rem calc(0.65rem + env(safe-area-inset-bottom));
    }

    .od-actions-inner {
        max-width: 720px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 0.5rem;
    }

    .od-actions .btn {
        border-radius: 12px;
        font-weight: 700;
        font-size: 0.85rem;
        padding: 0.65rem 0.4rem;
        white-space: nowrap;
    }

    @@media (min-width: 768px) {
        .od-page {
            padding: 1.25rem 1rem 2rem;
            min-height: auto;
        }

        .od-actions {
            position: static;
            background: transparent;
            backdrop-filter: none;
            border: none;
            padding: 0;
            margin-top: 0.25rem;
        }

        .od-actions-inner {
            display: flex;
            justify-content: flex-end;
            gap: 0.5rem;
        }

        .od-actions .btn {
            min-width: 140px;
        }
    }

    @@media (max-width: 380px) {
        .od-exchange {
            grid-template-columns: 1fr;
        }

        .od-arrow {
            transform: rotate(90deg);
            justify-self: center;
        }

        .od-meta {
            grid-template-columns: 1fr;
        }

        .od-actions-inner {
            grid-template-columns: 1fr;
        }
    }

    @@media print {
        .od-actions {
            display: none !important;
        }

        .od-page {
            padding: 0;
            min-height: auto;
        }
    }
</style>

<div class="od-page" id="orderReceipt">
    <div class="od-top">
        <div class="od-brand">
            @if (!string.IsNullOrWhiteSpace(logoDataUrl))
            {
                <img src="@logoDataUrl" alt="لوگو" />
            }
            <div class="od-brand-text">
                <div class="name">@websiteName</div>
                <div class="sub">جزئیات معامله</div>
            </div>
        </div>
        <span class="od-status @statusClass">@statusText</span>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show py-2" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show py-2" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="بستن"></button>
        </div>
    }

    <div class="od-card od-receipt">
        <div class="label">شماره رسید</div>
        <div class="number">@receiptNumber</div>
    </div>

    <div class="od-card od-customer">
        <div class="od-card-title">اطلاعات مشتری</div>
        @if (Model.Customer != null)
        {
            <div class="name">@customerTitle @Model.Customer.FullName</div>
            <div class="phone">@Model.Customer.PhoneNumber</div>
        }
        else
        {
            <div class="name">شناسه مشتری: @Model.CustomerId</div>
        }
    </div>

    <div class="od-card">
        <div class="od-card-title">جزئیات تبادل</div>
        <div class="od-exchange">
            <div class="od-amount receive">
                <span class="tag">دریافت می‌کنیم</span>
                <span class="value">@Model.FromAmount.FormatCurrency(fromCode)</span>
                <span class="currency">@fromLabel (@fromCode)</span>
            </div>
            <div class="od-arrow"><i class="fas fa-exchange-alt"></i></div>
            <div class="od-amount pay">
                <span class="tag">پرداخت می‌کنیم</span>
                <span class="value">@Model.ToAmount.FormatCurrency(toCode)</span>
                <span class="currency">@toLabel (@toCode)</span>
            </div>
        </div>
    </div>

    <div class="od-card">
        <div class="od-card-title">اطلاعات معامله</div>
        <div class="od-meta">
            <div class="od-meta-item">
                <span class="k">جفت ارز</span>
                <span class="v ltr">@fromCode / @toCode</span>
            </div>
            <div class="od-meta-item">
                <span class="k">نرخ تبدیل</span>
                <span class="v ltr">1 @fromCode = @Model.Rate.ToString("N4") @toCode</span>
            </div>
            <div class="od-meta-item">
                <span class="k">تاریخ تراکنش</span>
                <span class="v ltr">@Model.CreatedAt.ToString("yyyy/MM/dd HH:mm")</span>
            </div>
            <div class="od-meta-item">
                <span class="k">آخرین بروزرسانی</span>
                <span class="v ltr">
                    @(Model.UpdatedAt?.ToString("yyyy/MM/dd HH:mm") ?? "—")
                </span>
            </div>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Notes))
    {
        <div class="od-card">
            <div class="od-card-title">یادداشت‌ها</div>
            <div class="od-notes">@Model.Notes</div>
        </div>
    }

    @if (Model.IsDeleted && Model.DeletedAt.HasValue)
    {
        <div class="od-card">
            <div class="od-card-title">اطلاعات حذف</div>
            <div class="od-meta">
                <div class="od-meta-item">
                    <span class="k">تاریخ حذف</span>
                    <span class="v ltr">@Model.DeletedAt.Value.ToString("yyyy/MM/dd HH:mm")</span>
                </div>
                <div class="od-meta-item">
                    <span class="k">حذف توسط</span>
                    <span class="v">@(Model.DeletedBy ?? "—")</span>
                </div>
            </div>
        </div>
    }
</div>

<div class="od-actions d-print-none">
    <div class="od-actions-inner">
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-right"></i> بازگشت
        </a>
        <button type="button" id="screenshotReceiptBtn" class="btn btn-success">
            <i class="fas fa-camera"></i> تصویر
        </button>
        <button type="button" onclick="window.print()" class="btn btn-primary">
            <i class="fas fa-print"></i> چاپ
        </button>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/html2canvas@1.4.1/dist/html2canvas.min.js"></script>
    <script>
        (function () {
            const button = document.getElementById('screenshotReceiptBtn');
            const receipt = document.getElementById('orderReceipt');
            if (!button || !receipt || typeof html2canvas !== 'function') return;

            button.addEventListener('click', async function () {
                const originalText = button.innerHTML;
                button.disabled = true;
                button.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

                try {
                    const canvas = await html2canvas(receipt, {
                        backgroundColor: '#f4f6f8',
                        scale: Math.max(window.devicePixelRatio || 1, 2),
                        useCORS: true,
                        allowTaint: true
                    });

                    const link = document.createElement('a');
                    link.download = 'order-@(receiptNumber).png';
                    link.href = canvas.toDataURL('image/png');
                    link.click();
                } catch (error) {
                    console.error(error);
                    alert('خطا در تهیه تصویر.');
                } finally {
                    button.disabled = false;
                    button.innerHTML = originalText;
                }
            });
        })();
    </script>
}
