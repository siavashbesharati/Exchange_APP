@model ForexExchange.Models.ViewModels.RolePermissionViewModel
@using Microsoft.AspNetCore.Identity
@using ForexExchange.Models

@{
    ViewData["Title"] = "ویرایش دسترسی نقش ها";
}

<h1>@ViewData["Title"]</h1>
@if (TempData["Success"] != null)



{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (TempData["Error"] is string errorMessage)

{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @errorMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="row">
    <div class="col-md-8">
        <form asp-action="UpdateRolePermissions" method="post">
            <div asp-validation-summary="All" class="text-danger"></div>

            <div class="form-group mb-3">
                <label for="selectedRole" class="form-label"> انتخاب نقش:</label>

                <select id="selectedRole" name="selectedRoleName" class="form-control"
                    onchange="window.location.href = '/AdminManagement/ManageRolePermissions?roleName=' + this.value;">
                    @foreach (var role in Model.Roles)







                    {







                        var isSelected = Model.SelectedRole?.ToString() == role.Name;
                        <option value="@role.Name" selected="@(isSelected ? "selected" : null)">
                            @role.Name
                        </option>
                    }
                </select>
            </div>

            <h3> دسترسی ها برای : @Model.SelectedRole?.ToString()</h3>
            <div class="row">
                @foreach (var permission in Model.AllPermissions)







                {
                    <div class="col-md-4">
                        <div class="form-check">
                            <input type="checkbox" name="permissionNames" value="@permission" class="form-check-input"
                                id="permission_@permission.Replace(".", "_")"
                            @(Model.CurrentRolePermissions.Contains(permission) ? "checked" : "")>
                            <label class="form-check-label" for="permission_@permission.Replace(".", "_")">
                                @permission
                            </label>
                        </div>
                    </div>
                }
            </div>

            <button type="submit" class="btn btn-primary mt-3"> ذخیره دسترسی ها</button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
