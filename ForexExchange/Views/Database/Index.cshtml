
@using ForexExchange.Models
@model DatabaseManagementViewModel
@{
    ViewData["Title"] = "مدیریت پایگاه داده";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid mt-4" dir="rtl">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">
                        <i class="fas fa-database me-2"></i>
                        مدیریت پایگاه داده
                    </h4>
                </div>
                <div class="card-body">

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@Html.Raw(TempData["Success"]?.ToString() ?? "")</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }
                    @if (TempData["Info"] != null)
                    {
                        <div class="alert alert-info">@TempData["Info"]</div>
                    }
                    @if (TempData["DiagnosticInfo"] != null)
                    {
                        <div class="alert alert-secondary">
                            <h6>نتایج تشخیص:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["DiagnosticInfo"]</pre>
                        </div>
                    }
                    @if (TempData["CorrectionLog"] != null)
                    {
                        <div class="alert alert-warning">
                            <h6>لاگ اصلاحات:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["CorrectionLog"]</pre>
                        </div>
                    }
                    @if (TempData["ResetLog"] != null)
                    {
                        <div class="alert alert-info">
                            <h6>لاگ بازنشانی:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["ResetLog"]</pre>
                        </div>
                    }
                    @if (TempData["FixLog"] != null)
                    {
                        <div class="alert alert-warning">
                            <h6>لاگ اصلاح تاریخ‌ها:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["FixLog"]</pre>
                        </div>
                    }
                    @if (TempData["RecalcLog"] != null)
                    {
                        <div class="alert alert-primary">
                            <h6>لاگ بازمحاسبه موجودی‌ها:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["RecalcLog"]</pre>
                        </div>
                    }
                    @if (TempData["ConfirmationLog"] != null)
                    {
                        <div class="alert alert-success">
                            <h6>لاگ تایید اسناد:</h6>
                            <pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;">@TempData["ConfirmationLog"]</pre>
                        </div>
                    }

                    <!-- Database Statistics -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <h5 class="text-primary">آمار پایگاه داده</h5>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-info text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.CustomersCount</h4>
                                    <small>مشتریان</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-success text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.OrdersCount</h4>
                                    <small>معاملات</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-warning text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.CurrencyPoolsCount</h4>
                                    <small>داشبورد های ارز</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-secondary text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.TransactionsCount</h4>
                                    <small>تراکنش‌ها</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-danger text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.ExchangeRatesCount</h4>
                                    <small>نرخ‌های ارز</small>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-2 col-sm-4 col-6 mb-3">
                            <div class="card bg-dark text-white text-center">
                                <div class="card-body">
                                    <h4>@Model.AccountingDocumentsCount</h4>
                                    <small>اسناد حسابداری</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <!-- Backup & Restore Section -->
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-header bg-success text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-download me-2"></i>
                                        پشتیبان‌گیری و بازیابی
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <button type="button" class="btn btn-success w-100 mb-2" onclick="createBackup()">
                                            <i class="fas fa-download me-2"></i>
                                            ایجاد پشتیبان (قابل دانلود)
                                        </button>
                                    </div>
                                  
                                    
                                    <form asp-action="RestoreDatabase" method="post" enctype="multipart/form-data">
                                        @Html.AntiForgeryToken()
                                        <div class="mb-3">
                                            <label for="backupFile" class="form-label">فایل پشتیبان برای بازیابی:</label>
                                            <input type="file" class="form-control" id="backupFile" name="backupFile" accept=".db,.sql" required>
                                        </div>
                                        <button type="submit" class="btn btn-warning w-100" onclick="return confirmRestore()">
                                            <i class="fas fa-upload me-2"></i>
                                            بازیابی پایگاه داده
                                        </button>
                                    </form>

                                    <hr />
                                   
                                </div>
                            </div>
                        </div>

                        <!-- ورود یکپارچه داده مشتری (CSV) -->
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-header bg-primary text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-file-csv me-2"></i>
                                        ورود یکپارچه داده مشتری (CSV)
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <p class="text-muted small">اسناد (Receive/Pay) و سفارش‌ها (Buy/Sell) در یک فایل. هر فایل برای یک مشتری. ستون‌ها: date, type, currency, referenceNumber, amount, note</p>
                                    <form id="uploadCustomerCsvForm" enctype="multipart/form-data">
                                        @Html.AntiForgeryToken()
                                        <div class="mb-3">
                                            <label for="customerCsvFile" class="form-label">فایل CSV <span class="text-danger">*</span></label>
                                            <input type="file" class="form-control" id="customerCsvFile" name="csvFile" accept=".csv" required />
                                        </div>
                                        <div class="mb-3">
                                            <label for="uploadCustomerId" class="form-label">مشتری <span class="text-danger">*</span></label>
                                            <select class="form-select" id="uploadCustomerId" name="customerId" required>
                                                <option value="">انتخاب مشتری...</option>
                                                @if (ViewBag.Customers != null)
                                                {
                                                    @foreach (var item in ViewBag.Customers as IEnumerable<Microsoft.AspNetCore.Mvc.Rendering.SelectListItem>)
                                                    {
                                                        <option value="@item.Value">@item.Text</option>
                                                    }
                                                }
                                            </select>
                                        </div>
                                        <div id="uploadCustomerCsvResult" class="alert mb-0" style="display: none;" role="alert"></div>
                                        <button type="submit" class="btn btn-primary w-100" id="uploadCustomerCsvBtn">
                                            <i class="fas fa-upload me-2"></i> آپلود و ورود
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr>

                    <!-- Maintenance Section -->
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <div class="card h-100">
                                <div class="card-header bg-info text-white">
                                    <h5 class="mb-0">
                                        <i class="fas fa-tools me-2"></i>
                                        تعمیر و نگهداری
                                    </h5>
                                </div>
                                <div class="card-body">
                                    <div class="alert alert-info">
                                        <i class="fas fa-info-circle me-2"></i>
                                        ابزارهای تعمیر و نگهداری برای رفع مشکلات خاص
                                    </div>
                                    


                                    <form asp-action="ApplyPendingMigrations" method="post" class="mb-3" onsubmit="return confirm('آیا از اعمال migrationهای در حال انتظار مطمئن هستید؟ این عملیات ساختار پایگاه داده را تغییر خواهد داد.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-info w-100">
                                            <i class="fas fa-database me-2"></i>
                                            اعمال Migrationهای در حال انتظار
                                        </button>
                                    </form>

                                    <form id="freezeDashboardForm">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-primary w-100" id="freezeDashboardBtn">
                                            <i class="fas fa-snowflake me-2"></i>
                                               ریست داشبورد
                                        </button>
                                    </form>

                                    <form asp-action="UpdateNotesAndDescriptions" method="post" class="mt-3" onsubmit="return confirm('آیا از بروزرسانی یادداشت‌ها و توضیحات مطمئن هستید؟ این عملیات تمام Notes و Descriptions در جداول Orders، AccountingDocuments، CustomerBalanceHistory، CurrencyPoolHistory و BankAccountBalanceHistory را بروزرسانی خواهد کرد.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-info w-100">
                                            <i class="fas fa-edit me-2"></i>
                                            بروزرسانی یادداشت‌ها و توضیحات
                                        </button>
                                    </form>

                                    <form asp-action="RebuildAllFinancialBalances" method="post" class="mt-3" onsubmit="return confirm('آیا از بازسازی کامل موجودی‌های مالی مطمئن هستید؟ این عملیات تمام تاریخچه‌های موجودی را محاسبه‌ مجدد خواهد کرد.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-success w-100">
                                            <i class="fas fa-sync-alt me-2"></i>
                                            بازسازی کامل موجودی‌های مالی
                                        </button>
                                    </form>

                                    <form id="populateCurrencyIdsForm" class="mt-3">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-primary w-100" id="populateCurrencyIdsBtn">
                                            <i class="fas fa-exchange-alt me-2"></i>
                                            پر کردن CurrencyId از CurrencyCode
                                        </button>
                                    </form>

                                    <form asp-action="RegenerateVapidConfigurations" method="post" class="mt-3" onsubmit="return confirm('آیا از حذف تمام کلیدهای VAPID مطمئن هستید؟ کاربران پس از این عملیات باید اعلان فشاری را دوباره فعال کنند.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger w-100">
                                            <i class="fas fa-bell-slash me-2"></i>
                                            بازتولید تمام کلیدهای VAPID
                                        </button>
                                    </form>

                                    <form asp-action="DeleteAllPushSubscriptions" method="post" class="mt-3" onsubmit="return confirm('آیا از حذف همه اشتراک‌های اعلان فشاری مطمئن هستید؟ کاربران برای دریافت اعلان باید دوباره ثبت‌نام کنند.');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-warning w-100">
                                            <i class="fas fa-user-slash me-2"></i>
                                            حذف تمام اشتراک‌های اعلان فشاری
                                        </button>
                                    </form>

                                    <form id="removeDuplicatesForm" class="mt-3">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-outline-danger w-100" id="removeDuplicatesBtn">
                                            <i class="fas fa-trash-alt me-2"></i>
                                            حذف رکوردهای تکراری تاریخچه
                                        </button>
                                    </form>

                                </div>
                            </div>
                        </div>

                  
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Loading Modal -->
<div class="modal fade" id="loadingModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-body text-center">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">در حال پردازش...</span>
                </div>
                <div class="mt-3">در حال پردازش، لطفاً صبر کنید...</div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function createBackup() {
            $('#loadingModal').modal('show');

            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '@Url.Action("CreateBackup")';
            form.style.display = 'none';

            var token = $('input[name="__RequestVerificationToken"]').val();
            if (token) {
                var csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = '__RequestVerificationToken';
                csrfInput.value = token;
                form.appendChild(csrfInput);
            }

            document.body.appendChild(form);
            form.submit();
            document.body.removeChild(form);

            setTimeout(function () {
                $('#loadingModal').modal('hide');
                Swal.fire('موفق!', 'پشتیبان با موفقیت ایجاد و دانلود شد!', 'success');
            }, 1000);
        }

        function confirmRestore() {
            return confirm('آیا مطمئن هستید که می‌خواهید پایگاه داده را بازیابی کنید؟ این عمل تمام اطلاعات فعلی را جایگزین خواهد کرد.');
        }

        $(function () {
            $('#uploadCustomerCsvForm').on('submit', async function (e) {
                e.preventDefault();
                var form = e.target;
                var fileInput = document.getElementById('customerCsvFile');
                var customerSelect = document.getElementById('uploadCustomerId');
                var resultDiv = document.getElementById('uploadCustomerCsvResult');
                var btn = document.getElementById('uploadCustomerCsvBtn');
                if (!fileInput.files || fileInput.files.length === 0) {
                    resultDiv.className = 'alert alert-danger';
                    resultDiv.style.display = 'block';
                    resultDiv.innerHTML = 'لطفاً یک فایل CSV انتخاب کنید.';
                    return;
                }
                if (!customerSelect.value) {
                    resultDiv.className = 'alert alert-danger';
                    resultDiv.style.display = 'block';
                    resultDiv.innerHTML = 'لطفاً یک مشتری انتخاب کنید.';
                    return;
                }
                btn.disabled = true;
                resultDiv.style.display = 'none';
                var formData = new FormData();
                formData.append('csvFile', fileInput.files[0]);
                formData.append('customerId', customerSelect.value);
                formData.append('__RequestVerificationToken', form.querySelector('input[name="__RequestVerificationToken"]').value);
                try {
                    var response = await fetch('@Url.Action("UploadCustomerCsv", "Database")', { method: 'POST', body: formData });
                    var contentType = response.headers.get('content-type') || '';
                    var data;
                    if (contentType.indexOf('application/json') !== -1) {
                        data = await response.json();
                    } else {
                        var text = await response.text();
                        throw new Error(response.ok ? ('پاسخ نامعتبر: ' + text.substring(0, 200)) : ('خطا ' + response.status + ': ' + (text || response.statusText)));
                    }
                    resultDiv.style.display = 'block';
                    if (data.success) {
                        resultDiv.className = 'alert alert-success';
                        var html = '<strong>' + data.message + '</strong>';
                        if (data.importedDocs !== undefined) html += '<br/>اسناد جدید: ' + data.importedDocs;
                        if (data.updatedDocs !== undefined) html += ' | اسناد به‌روز (طرف دوم): ' + data.updatedDocs;
                        if (data.skippedDocs !== undefined && data.skippedDocs > 0) html += ' | رد شده: ' + data.skippedDocs;
                        if (data.importedOrders !== undefined) html += '<br/>سفارش‌های وارد شده: ' + data.importedOrders;
                        if (data.skippedOrders !== undefined && data.skippedOrders > 0) html += ' | سفارش رد شده: ' + data.skippedOrders;
                        if (data.duplicateForReview && data.duplicateForReview.length > 0) {
                            html += '<br/><small>برای بررسی دستی: ';
                            data.duplicateForReview.forEach(function (x) { html += (x.refId || '') + ': ' + (x.reason || '') + '; '; });
                            html += '</small>';
                        }
                        if (data.errors && data.errors.length > 0) {
                            html += '<br/><small>خطاها: ';
                            data.errors.forEach(function (err) { html += (err.refId || '') + ': ' + (err.message || '') + '; '; });
                            html += '</small>';
                        }
                        resultDiv.innerHTML = html;
                    } else {
                        resultDiv.className = 'alert alert-danger';
                        resultDiv.innerHTML = (data.message || 'خطا در آپلود') + (data.errors && data.errors.length ? '<br/><small>' + data.errors.map(function (e) { return e.message; }).join('; ') + '</small>' : '');
                    }
                } catch (err) {
                    resultDiv.className = 'alert alert-danger';
                    resultDiv.style.display = 'block';
                    resultDiv.innerHTML = 'خطا در ارتباط با سرور: ' + err.message;
                }
                btn.disabled = false;
            });
        });

        function cleanCustomers() {
        }

        function cleanOrders() {
        }

        function cleanPools() {
        }
        // Clean actions are now regular POST forms to ensure TempData shows after redirect

        function getTransactionNumberReport() {
            $('#loadingModal').modal('show');

            $.get('@Url.Action("GetTransactionNumberReport")')
                .done(function (response) {
                    $('#loadingModal').modal('hide');
                    
                    if (response.success) {
                        var report = response.report;
                        var summary = response.summary;
                        
                        var reportHtml = `
                            <div style="text-align: right; direction: rtl;">
                                <h5>📊 گزارش پوشش شماره تراکنش</h5>
                                <hr>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h6>👥 CustomerBalanceHistory (نوع سند حسابداری):</h6>
                                        <ul>
                                            <li>کل رکوردها: <strong>${report.customerBalanceHistoryTotal.toLocaleString()}</strong></li>
                                            <li>با شماره تراکنش: <strong>${report.customerBalanceHistoryWithTransactionNumber.toLocaleString()}</strong></li>
                                            <li>بدون شماره تراکنش: <strong>${report.customerBalanceHistoryWithoutTransactionNumber.toLocaleString()}</strong></li>
                                            <li>شماره تراکنش متفاوت: <strong style="color: orange;">${report.customerBalanceHistoryMismatched.toLocaleString()}</strong></li>
                                            <li>پوشش: <strong>${report.customerBalanceHistoryCoveragePercentage.toFixed(1)}%</strong></li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h6>🏦 BankAccountBalanceHistory (نوع سند):</h6>
                                        <ul>
                                            <li>کل رکوردها: <strong>${report.bankAccountBalanceHistoryTotal.toLocaleString()}</strong></li>
                                            <li>با شماره تراکنش: <strong>${report.bankAccountBalanceHistoryWithTransactionNumber.toLocaleString()}</strong></li>
                                            <li>بدون شماره تراکنش: <strong>${report.bankAccountBalanceHistoryWithoutTransactionNumber.toLocaleString()}</strong></li>
                                            <li>شماره تراکنش متفاوت: <strong style="color: orange;">${report.bankAccountBalanceHistoryMismatched.toLocaleString()}</strong></li>
                                            <li>پوشش: <strong>${report.bankAccountBalanceHistoryCoveragePercentage.toFixed(1)}%</strong></li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-12">
                                        <h6>📄 AccountingDocuments:</h6>
                                        <ul>
                                            <li>کل اسناد: <strong>${report.accountingDocumentsTotal.toLocaleString()}</strong></li>
                                            <li>با شماره تراکنش: <strong>${report.accountingDocumentsWithReferenceNumber.toLocaleString()}</strong></li>
                                            <li>بدون شماره تراکنش: <strong>${report.accountingDocumentsWithoutReferenceNumber.toLocaleString()}</strong></li>
                                            <li>پوشش: <strong>${report.accountingDocumentsCoveragePercentage.toFixed(1)}%</strong></li>
                                        </ul>
                                    </div>
                                </div>
                                
                                <div class="alert alert-info">
                                    <i class="fas fa-info-circle me-2"></i>
                                    <strong>خلاصه:</strong><br>
                                    • مشتری: ${summary.customerCoverage}<br>
                                    • بانک: ${summary.bankCoverage}<br>
                                    • اسناد: ${summary.documentCoverage}
                                </div>
                            </div>
                        `;
                        
                        Swal.fire({
                            title: 'گزارش شماره تراکنش',
                            html: reportHtml,
                            width: '800px',
                            confirmButtonText: 'بستن',
                            confirmButtonColor: '#3085d6'
                        });
                    } else {
                        Swal.fire('خطا!', response.error || 'خطا در تولید گزارش', 'error');
                    }
                })
                .fail(function (xhr, status, error) {
                    $('#loadingModal').modal('hide');
                    Swal.fire('خطا!', 'خطا در ارتباط با سرور: ' + error, 'error');
                });
        }

        $(document).ready(function() {
            $('#freezeDashboardForm').on('submit', function (e) {
                e.preventDefault();

                if (!confirm('آیا مطمئن هستید که می‌خواهید همه سفارش‌ها و اسناد حسابداری را منجمد کنید؟\n\n🔒 سفارش‌ها و اسنادی که منجمد می‌شوند از محاسبات جاری حذف خواهند شد اما در تاریخچه باقی می‌مانند.')) {
                    return;
                }

                var $form = $(this);
                var $button = $('#freezeDashboardBtn');
                var originalButtonHtml = $button.html();

                $button.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> در حال اجرا...').prop('disabled', true);

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("FreezeAllOrdersAndDocuments", "Database")',
                    data: $form.serialize(),
                    success: function (response) {
                        if (response.success) {
                            Swal.fire({
                                icon: 'success',
                                title: 'عملیات با موفقیت انجام شد',
                                html: response.message
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'خطا در عملیات',
                                text: response.error || 'خطای ناشناخته رخ داد.'
                            });
                        }
                    },
                    error: function () {
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا در ارتباط با سرور',
                            text: 'لطفاً مجدداً تلاش کنید.'
                        });
                    },
                    complete: function () {
                        $button.html(originalButtonHtml).prop('disabled', false);
                    }
                });
            });

            // Populate CurrencyIds Form Handler
            $('#populateCurrencyIdsForm').on('submit', function (e) {
                e.preventDefault();

                if (!confirm('آیا مطمئن هستید که می‌خواهید CurrencyId را از CurrencyCode پر کنید؟\n\n⚠️ این عملیات:\n• CustomerBalances\n• CustomerBalanceHistory\n• CurrencyPoolHistory\n• AccountingDocuments\n\nرا بروزرسانی می‌کند. این عملیات برای تکمیل migration از CurrencyCode به CurrencyId ضروری است.')) {
                    return;
                }

                var $form = $(this);
                var $button = $('#populateCurrencyIdsBtn');
                var originalButtonHtml = $button.html();

                $button.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> در حال اجرا...').prop('disabled', true);

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("PopulateCurrencyIds", "Database")',
                    data: $form.serialize(),
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (response) {
                        if (response.success) {
                            var message = response.message || 'Migration با موفقیت انجام شد.';
                            var details = '';
                            if (response.details && Array.isArray(response.details)) {
                                details = '<br/><br/><strong>جزئیات:</strong><br/>';
                                details += response.details.join('<br/>');
                            }
                            
                            Swal.fire({
                                icon: 'success',
                                title: 'عملیات با موفقیت انجام شد',
                                html: message + details,
                                confirmButtonText: 'بستن',
                                width: '800px'
                            }).then(function() {
                                // Reload page to show updated data
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'خطا در عملیات',
                                text: response.error || 'خطای ناشناخته رخ داد.'
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        var errorMessage = 'خطا در ارتباط با سرور';
                        if (xhr.responseJSON && xhr.responseJSON.error) {
                            errorMessage = xhr.responseJSON.error;
                        } else if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                errorMessage = response.error || errorMessage;
                            } catch (e) {
                                errorMessage = error || errorMessage;
                            }
                        }
                        
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا در ارتباط با سرور',
                            text: errorMessage
                        });
                    },
                    complete: function () {
                        $button.html(originalButtonHtml).prop('disabled', false);
                    }
                });
            });

            // Remove Duplicates Form Handler
            $('#removeDuplicatesForm').on('submit', function (e) {
                e.preventDefault();

                if (!confirm('آیا مطمئن هستید که می‌خواهید رکوردهای تکراری را حذف کنید؟\n\n⚠️ این عملیات رکوردهای تکراری در:\n• BankAccountBalanceHistory\n• CustomerBalanceHistory\n\nرا حذف می‌کند. معیار تکراری بودن: TransactionAmount, TransactionDate, TransactionType\n\nفقط اولین رکورد (با کمترین Id) باقی می‌ماند.')) {
                    return;
                }

                var $form = $(this);
                var $button = $('#removeDuplicatesBtn');
                var originalButtonHtml = $button.html();

                $button.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> در حال حذف تکراری‌ها...').prop('disabled', true);

                $.ajax({
                    type: 'POST',
                    url: '@Url.Action("RemoveDuplicateHistoryRecords", "Database")',
                    data: $form.serialize(),
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function (response) {
                        if (response.success) {
                            var message = response.message || 'حذف تکراری‌ها با موفقیت انجام شد.';
                            var details = '';
                            if (response.bankDeletedCount !== undefined || response.customerDeletedCount !== undefined) {
                                details = `<br/><br/><strong>جزئیات:</strong><br/>`;
                                details += `• BankAccountBalanceHistory: ${response.bankDeletedCount || 0} رکورد حذف شد<br/>`;
                                details += `• CustomerBalanceHistory: ${response.customerDeletedCount || 0} رکورد حذف شد<br/>`;
                                details += `• مجموع: ${response.totalDeleted || 0} رکورد حذف شد`;
                            }
                            
                            Swal.fire({
                                icon: 'success',
                                title: 'عملیات با موفقیت انجام شد',
                                html: message + details,
                                confirmButtonText: 'بستن'
                            }).then(function() {
                                // Reload page to show updated data
                                location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'خطا در عملیات',
                                text: response.error || 'خطای ناشناخته رخ داد.'
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        var errorMessage = 'خطا در ارتباط با سرور';
                        if (xhr.responseJSON && xhr.responseJSON.error) {
                            errorMessage = xhr.responseJSON.error;
                        } else if (xhr.responseText) {
                            try {
                                var response = JSON.parse(xhr.responseText);
                                errorMessage = response.error || errorMessage;
                            } catch (e) {
                                errorMessage = error || errorMessage;
                            }
                        }
                        
                        Swal.fire({
                            icon: 'error',
                            title: 'خطا در ارتباط با سرور',
                            text: errorMessage
                        });
                    },
                    complete: function () {
                        $button.html(originalButtonHtml).prop('disabled', false);
                    }
                });
            });

            // Confirmation for dangerous actions
            $('#cleanCustomersBtn, #cleanOrdersBtn, #cleanPoolsBtn, #restoreForm button[type=submit], #resetAccountingBtn, #recalculateBalancesBtn').click(function(e) {
                var message = $(this).data('confirm');
                if (!confirm(message)) {
                    e.preventDefault();
                }
            });

            // AJAX call for Recalculate All Balances
            $('#recalculateBalancesBtn').click(function(e) {
                e.preventDefault();
                var form = $(this).closest('form');
                var url = form.attr('action');
                
                // Show loading indicator
                var originalButtonText = $(this).html();
                $(this).html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> در حال محاسبه...').prop('disabled', true);

                $.ajax({
                    type: "POST",
                    url: url,
                    data: form.serialize(),
                    headers: {
                        "X-Requested-With": "XMLHttpRequest"
                    },
                    success: function(response) {
                        if (response.success) {
                            // Create a success alert
                            var alert = $('<div class="alert alert-success alert-dismissible fade show" role="alert"></div>');
                            alert.html(response.message.replace(/\\n/g, '<br/>') + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                            $('.card-body').prepend(alert);
                            // Optionally show log
                            if(response.log) {
                                var logAlert = $('<div class="alert alert-primary"><h6>لاگ بازمحاسبه:</h6><pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;"></pre></div>');
                                logAlert.find('pre').text(response.log);
                                $('.card-body').prepend(logAlert);
                            }
                        } else {
                            var alert = $('<div class="alert alert-danger alert-dismissible fade show" role="alert"></div>');
                            alert.html(response.error + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                            $('.card-body').prepend(alert);
                        }
                    },
                    error: function() {
                        var alert = $('<div class="alert alert-danger alert-dismissible fade show" role="alert"></div>');
                        alert.html('خطای ناشناخته در ارتباط با سرور رخ داد.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                        $('.card-body').prepend(alert);
                    },
                    complete: function() {
                        // Restore button
                        $('#recalculateBalancesBtn').html(originalButtonText).prop('disabled', false);
                    }
                });
            });

            // AJAX call for Apply Rounding
            $('#applyRoundingBtn').click(function(e) {
                e.preventDefault();
                if (!confirm('آیا از گرد کردن تمام مقادیر پولی در پایگاه داده مطمئن هستید؟ این عملیات غیرقابل بازگشت است.')) {
                    return;
                }

                var button = $(this);
                var originalButtonText = button.html();
                button.html('<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> در حال اجرا...').prop('disabled', true);

                $.ajax({
                    type: "POST",
                    url: '@Url.Action("ApplyDatabaseRounding", "Database")',
                    headers: {
                        "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function(response) {
                        if (response.success) {
                            var alert = $('<div class="alert alert-success alert-dismissible fade show" role="alert"></div>');
                            alert.html(response.message.replace(/\\n/g, '<br/>') + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                            
                            var summaryAlert = $('<div class="alert alert-info"><h6>خلاصه عملیات:</h6><pre style="white-space: pre-wrap; max-height: 300px; overflow-y: auto;"></pre></div>');
                            summaryAlert.find('pre').text(response.summary);

                            $('.card-body').prepend(summaryAlert).prepend(alert);
                        } else {
                            var alert = $('<div class="alert alert-danger alert-dismissible fade show" role="alert"></div>');
                            alert.html(response.error + '<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                            $('.card-body').prepend(alert);
                        }
                    },
                    error: function() {
                        var alert = $('<div class="alert alert-danger alert-dismissible fade show" role="alert"></div>');
                        alert.html('خطای ناشناخته در ارتباط با سرور رخ داد.<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>');
                        $('.card-body').prepend(alert);
                    },
                    complete: function() {
                        button.html(originalButtonText).prop('disabled', false);
                    }
                });
            });
        });
    </script>
}

